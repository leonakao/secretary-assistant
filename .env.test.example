# Optional overrides for the isolated onboarding-validation stack.
#
# The stack loads:
# - api/.env
# - web/.env
# - .env.test
#
# Only place values here when the validation stack should override the app
# defaults.

# Required today if you want the isolated stack to override or replace the app
# defaults for AI providers.
# OPENAI_API_KEY=your_openai_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

