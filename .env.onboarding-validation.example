# Copy this file to `.env.onboarding-validation` before starting the
# onboarding-validation stack.

# Compose/runtime isolation
ONBOARDING_VALIDATION_COMPOSE_PROJECT_NAME=secretary-assistant-onboarding-validation
ONBOARDING_VALIDATION_WEB_PORT=4173
ONBOARDING_VALIDATION_API_PORT=3300
ONBOARDING_VALIDATION_DB_PORT=55432

# API
ONBOARDING_VALIDATION_GOOGLE_API_KEY=your_google_api_key_here
ONBOARDING_VALIDATION_EVOLUTION_API_KEY=change-me
ONBOARDING_VALIDATION_EVOLUTION_API_URL=http://127.0.0.1:9
ONBOARDING_VALIDATION_EVOLUTION_API_TOKEN=change-me

# Auth contract used by the isolated onboarding-validation stack.
ONBOARDING_VALIDATION_AUTH0_DOMAIN=dev-du3tsou284mgwefg.us.auth0.com
ONBOARDING_VALIDATION_AUTH0_CLIENT_ID=SJtvoRN584unasTOBo2fYogJM8HaWjWU

# Web
ONBOARDING_VALIDATION_VITE_API_BASE_URL=/api
ONBOARDING_VALIDATION_VITE_AUTH0_APP_ORIGIN=http://localhost:4173
ONBOARDING_VALIDATION_BASE_URL=http://127.0.0.1:4173
ONBOARDING_VALIDATION_API_BASE_URL=http://127.0.0.1:3300
